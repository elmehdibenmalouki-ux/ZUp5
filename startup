#!/bin/bash

echo "بدء تشغيل بوت ZUp..."

# تأكد من وجود المتطلبات (أعد تثبيتها تحسباً)
pip install --no-cache-dir -r requirements.txt

# البحث عن الوحدة الرئيسية: جرب zlzl أولاً، ثم main.py
if python -c "import zlzl" 2>/dev/null; then
    echo "تشغيل الوحدة zlzl"
    python -m zlzl
elif [ -f "main.py" ]; then
    echo "تشغيل main.py"
    python main.py
else
    echo "لم يتم العثور على ملف التشغيل الرئيسي!"
    exit 1
fi
